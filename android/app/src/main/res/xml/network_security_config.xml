<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTPS traffic to SnapSolve API -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">snapsolve.ai</domain>
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
    </domain-config>
    <!-- Block all cleartext HTTP traffic for security -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
